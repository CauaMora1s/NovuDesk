# ─── Application ──────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=change-me-in-production-32-chars-min

# ─── Database ─────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=novudesk
DB_USER=novudesk
DB_PASSWORD=novudesk
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25

# ─── Redis ────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ──────────────────────────────────────────────────────
# Generate RSA key pair: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH=./config/keys/private.pem
JWT_PUBLIC_KEY_PATH=./config/keys/public.pem
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@novudesk.dev
SMTP_FROM_NAME=NovuDesk

# ─── Storage ──────────────────────────────────────────────────
# local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads

# S3 / R2 / MinIO (only when STORAGE_DRIVER=s3)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=novudesk
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
